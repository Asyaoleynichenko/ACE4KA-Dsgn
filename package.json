{
  "name": "ace4ka",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/check-deps.mjs",
    "prestart": "node scripts/check-deps.mjs",
    "dev": "vite",
    "dev:host": "vite --host",
    "start": "vite",
    "build": "vite build && node -e \"const fs=require('fs');fs.copyFileSync('dist/index.html','dist/404.html');fs.writeFileSync('dist/.nojekyll','')\"",
    "build:local": "vite build --base / && node -e \"const fs=require('fs');fs.copyFileSync('dist/index.html','dist/404.html');fs.writeFileSync('dist/.nojekyll','')\"",
    "preview": "vite preview",
    "build:root": "VITE_BASE=root vite build && node -e \"require('fs').copyFileSync('dist/index.html','dist/404.html')\"",
    "export:images": "node scripts/export-all-images.mjs"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "framer-motion": "^11.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "styled-components": "^6.4.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "vite": "^4.5.0"
  },
  "engines": {
    "node": ">=14.18"
  }
}
